<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ReqPOOL Ausschreibungs-Scout</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --color-primary: #002EB1;
            --color-secondary: #19B874;
            --color-accent-green: #63F185;
            --color-accent-blue: #1464F4;
            --color-grey: #556D73;
            --color-black: #000000;
            --color-white: #FFFFFF;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'IBM Plex Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            color: var(--color-black);
            background: var(--color-white);
            line-height: 1.5;
        }

        .header {
            background: var(--color-primary);
            color: var(--color-white);
            padding: 1.5rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .header h1 {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .header .subtitle {
            font-size: 0.95rem;
            opacity: 0.85;
            font-weight: 400;
        }

        .header .updated {
            font-size: 0.85rem;
            opacity: 0.75;
        }

        .stats {
            background: #f5f7fa;
            padding: 1rem 2rem;
            display: flex;
            gap: 2rem;
            align-items: center;
            flex-wrap: wrap;
            border-bottom: 2px solid var(--color-primary);
        }

        .stat-item {
            font-size: 0.95rem;
            color: var(--color-grey);
        }

        .stat-item strong {
            color: var(--color-primary);
            font-weight: 600;
        }

        .stat-new strong {
            color: var(--color-secondary);
        }

        /* Toolbar */
        .toolbar {
            padding: 1rem 2rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            border-bottom: 1px solid #e5e7eb;
        }

        .toolbar-search {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .search-input {
            border: 1px solid var(--color-primary);
            border-radius: 4px;
            padding: 0.5rem 1rem;
            width: 100%;
            max-width: 400px;
            font-family: inherit;
            font-size: 0.9rem;
            outline: none;
        }

        .search-input:focus {
            box-shadow: 0 0 0 2px rgba(0, 46, 177, 0.2);
        }

        .search-clear {
            background: none;
            border: 1px solid #e5e7eb;
            border-radius: 4px;
            padding: 0.5rem 0.75rem;
            cursor: pointer;
            font-size: 0.85rem;
            color: var(--color-grey);
            font-family: inherit;
            display: none;
        }

        .search-clear.visible {
            display: inline-block;
        }

        .toolbar-filters {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .toolbar-filters label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--color-grey);
            margin-right: 0.25rem;
        }

        .toolbar-sort {
            display: flex;
            gap: 0.5rem;
            align-items: center;
            flex-wrap: wrap;
        }

        .toolbar-sort label {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--color-grey);
            margin-right: 0.25rem;
        }

        .filter-btn, .sort-btn {
            padding: 0.35rem 0.85rem;
            border: 1px solid var(--color-primary);
            background: var(--color-white);
            color: var(--color-primary);
            border-radius: 4px;
            cursor: pointer;
            font-family: inherit;
            font-size: 0.8rem;
            font-weight: 500;
            transition: background 0.15s, color 0.15s;
        }

        .filter-btn:hover, .sort-btn:hover {
            background: var(--color-primary);
            color: var(--color-white);
        }

        .filter-btn.active, .sort-btn.active {
            background: var(--color-primary);
            color: var(--color-white);
        }

        .visible-count {
            color: var(--color-grey);
            font-size: 0.85rem;
            margin-left: auto;
        }

        /* Table */
        .table-wrapper {
            overflow-x: auto;
            padding: 0 2rem 2rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.9rem;
        }

        thead th {
            background: var(--color-primary);
            color: var(--color-white);
            padding: 0.75rem 1rem;
            text-align: left;
            font-weight: 600;
            white-space: nowrap;
        }

        tbody td {
            padding: 0.65rem 1rem;
            border-bottom: 1px solid #e5e7eb;
            vertical-align: top;
        }

        tbody tr:hover {
            background: #f9fafb;
        }

        .badge-neu {
            display: inline-block;
            background: var(--color-secondary);
            color: var(--color-white);
            font-size: 0.7rem;
            font-weight: 700;
            padding: 0.15rem 0.5rem;
            border-radius: 3px;
            text-transform: uppercase;
            margin-left: 0.5rem;
            vertical-align: middle;
        }

        .badge-relevant {
            display: none;
            background: var(--color-secondary);
            color: var(--color-white);
            font-size: 0.65rem;
            font-weight: 700;
            padding: 0.1rem 0.4rem;
            border-radius: 3px;
            margin-left: 0.3rem;
            vertical-align: middle;
        }

        .source-tag {
            display: inline-block;
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--color-accent-blue);
        }

        a {
            color: var(--color-accent-blue);
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }

        .link-btn {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            background: var(--color-accent-blue);
            color: var(--color-white);
            border-radius: 3px;
            font-size: 0.8rem;
            font-weight: 500;
            text-decoration: none;
        }

        .link-btn:hover {
            opacity: 0.9;
            text-decoration: none;
        }

        /* Relevance */
        .relevance-cell {
            min-width: 120px;
        }

        .relevance-bar {
            display: inline-block;
            width: 50px;
            height: 6px;
            background: #e5e7eb;
            border-radius: 3px;
            vertical-align: middle;
            margin-right: 0.3rem;
        }

        .relevance-fill {
            display: block;
            height: 100%;
            border-radius: 3px;
            background: var(--color-secondary);
        }

        .relevance-high .relevance-fill {
            background: var(--color-accent-green);
        }

        .relevance-score {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--color-primary);
            vertical-align: middle;
        }

        .relevance-zero {
            color: var(--color-grey);
            opacity: 0.5;
        }

        .relevance-tags {
            display: block;
            font-size: 0.7rem;
            color: var(--color-grey);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 160px;
            margin-top: 0.15rem;
        }

        .footer {
            background: #f5f7fa;
            color: var(--color-grey);
            text-align: center;
            padding: 1rem 2rem;
            font-size: 0.8rem;
            border-top: 1px solid #e5e7eb;
        }

        .empty-state {
            text-align: center;
            padding: 3rem 2rem;
            color: var(--color-grey);
        }

        @media (max-width: 768px) {
            .header {
                padding: 1rem;
                flex-direction: column;
                align-items: flex-start;
            }

            .header h1 {
                font-size: 1.2rem;
            }

            .stats {
                padding: 0.75rem 1rem;
                gap: 1rem;
            }

            .toolbar {
                padding: 0.75rem 1rem;
            }

            .search-input {
                max-width: 100%;
            }

            .table-wrapper {
                padding: 0 0.5rem 1rem;
            }

            thead th, tbody td {
                padding: 0.5rem 0.5rem;
                font-size: 0.8rem;
            }

            .hide-mobile {
                display: none;
            }

            .badge-relevant {
                display: inline-block;
            }
        }
    </style>
</head>
<body>
    <header class="header">
        <div>
            <h1>ReqPOOL Ausschreibungs-Scout</h1>
            <div class="subtitle">Energie &amp; IT</div>
        </div>
        <div class="updated">Aktualisiert: {{ updated_at }}</div>
    </header>

    <div class="stats">
        <div class="stat-item">
            Gesamt <strong>{{ total_count }}</strong> Ausschreibungen
        </div>
        <div class="stat-item stat-new">
            <strong>{{ new_count }}</strong> neu heute
        </div>
    </div>

    <div class="toolbar">
        <div class="toolbar-search">
            <input type="text" class="search-input" placeholder="Suche in Titel, Auftraggeber..." aria-label="Suche">
            <button class="search-clear" title="Suche leeren">&#x2715;</button>
        </div>

        <div class="toolbar-filters">
            <label>Quellen:</label>
            <button class="filter-btn active" data-source="all">Alle</button>
            {% for source in sources %}
            <button class="filter-btn" data-source="{{ source }}">{{ source }}</button>
            {% endfor %}
        </div>

        <div class="toolbar-sort">
            <label>Sortierung:</label>
            <button class="sort-btn active" data-sort="date">Datum <span class="sort-arrow">&#x25BC;</span></button>
            <button class="sort-btn" data-sort="relevance">Relevanz <span class="sort-arrow">&#x25BC;</span></button>
            <span class="visible-count">Zeige: {{ total_count }} von {{ total_count }}</span>
        </div>
    </div>

    <div class="table-wrapper">
        {% if all_entries %}
        <table>
            <thead>
                <tr>
                    <th>Quelle</th>
                    <th>Titel</th>
                    <th class="hide-mobile">Relevanz</th>
                    <th class="hide-mobile">Auftraggeber</th>
                    <th>Datum</th>
                    <th class="hide-mobile">Frist</th>
                    <th>Link</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in all_entries %}
                <tr data-source="{{ entry.source }}" data-score="{{ entry.relevance_score }}" data-published="{{ entry.published_iso }}">
                    <td><span class="source-tag">{{ entry.source }}</span></td>
                    <td>
                        <a href="{{ entry.url }}" target="_blank" rel="noopener">{{ entry.title }}</a>
                        {% if entry.id in new_ids %}<span class="badge-neu">NEU</span>{% endif %}
                        {% if entry.relevance_score >= 50 %}<span class="badge-relevant">{{ entry.relevance_score }}%</span>{% endif %}
                    </td>
                    <td class="hide-mobile relevance-cell">
                        {% if entry.relevance_score > 0 %}
                        <span class="relevance-bar{% if entry.relevance_score >= 60 %} relevance-high{% endif %}">
                            <span class="relevance-fill" style="width: {{ entry.relevance_score }}%"></span>
                        </span>
                        <span class="relevance-score">{{ entry.relevance_score }}</span>
                        {% if entry.matched_roles %}
                        <span class="relevance-tags" title="{{ entry.matched_roles | join(', ') }}">
                            {{ entry.matched_roles[:2] | join(', ') }}{% if entry.matched_roles | length > 2 %} +{{ entry.matched_roles | length - 2 }}{% endif %}
                        </span>
                        {% endif %}
                        {% else %}
                        <span class="relevance-score relevance-zero">–</span>
                        {% endif %}
                    </td>
                    <td class="hide-mobile">{{ entry.buyer }}</td>
                    <td>{{ entry.published }}</td>
                    <td class="hide-mobile">{{ entry.deadline }}</td>
                    <td>
                        {% if entry.url %}
                        <a class="link-btn" href="{{ entry.url }}" target="_blank" rel="noopener">Öffnen</a>
                        {% else %}
                        –
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty-state">
            <p>Keine Ausschreibungen gefunden.</p>
        </div>
        {% endif %}
    </div>

    <footer class="footer">
        Automatisch aktualisiert via GitHub Actions &middot; ReqPOOL GmbH
    </footer>

    <script>
        var TenderScout = {
            activeSource: 'all',
            activeSort: 'date',
            sortDirection: 'desc',
            searchTerm: ''
        };

        function applyFilters() {
            var rows = document.querySelectorAll('tbody tr');
            var visibleCount = 0;
            for (var j = 0; j < rows.length; j++) {
                var row = rows[j];
                var source = row.getAttribute('data-source');
                var text = row.textContent.toLowerCase();

                var sourceMatch = (TenderScout.activeSource === 'all' ||
                                  source === TenderScout.activeSource);
                var searchMatch = (!TenderScout.searchTerm ||
                                  text.indexOf(TenderScout.searchTerm) !== -1);

                if (sourceMatch && searchMatch) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            }
            var countEl = document.querySelector('.visible-count');
            if (countEl) {
                countEl.textContent = 'Zeige: ' + visibleCount + ' von ' + rows.length;
            }
        }

        function searchTable(term) {
            TenderScout.searchTerm = term.toLowerCase().trim();
            applyFilters();
            var clearBtn = document.querySelector('.search-clear');
            if (clearBtn) {
                clearBtn.classList.toggle('visible', term.length > 0);
            }
        }

        function filterSource(source) {
            TenderScout.activeSource = source;
            var buttons = document.querySelectorAll('.filter-btn');
            for (var i = 0; i < buttons.length; i++) {
                var isActive = buttons[i].getAttribute('data-source') === source;
                buttons[i].classList.toggle('active', isActive);
            }
            applyFilters();
        }

        function doSort() {
            var tbody = document.querySelector('tbody');
            if (!tbody) return;
            var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
            rows.sort(function(a, b) {
                var valA, valB;
                if (TenderScout.activeSort === 'relevance') {
                    valA = parseInt(a.getAttribute('data-score') || '0', 10);
                    valB = parseInt(b.getAttribute('data-score') || '0', 10);
                } else {
                    valA = a.getAttribute('data-published') || '';
                    valB = b.getAttribute('data-published') || '';
                }
                var cmp = (valA < valB) ? -1 : (valA > valB) ? 1 : 0;
                return TenderScout.sortDirection === 'desc' ? -cmp : cmp;
            });
            for (var i = 0; i < rows.length; i++) {
                tbody.appendChild(rows[i]);
            }
        }

        function sortTable(field) {
            if (TenderScout.activeSort === field) {
                TenderScout.sortDirection =
                    TenderScout.sortDirection === 'desc' ? 'asc' : 'desc';
            } else {
                TenderScout.activeSort = field;
                TenderScout.sortDirection = 'desc';
            }
            var sortBtns = document.querySelectorAll('.sort-btn');
            for (var i = 0; i < sortBtns.length; i++) {
                var btnField = sortBtns[i].getAttribute('data-sort');
                sortBtns[i].classList.toggle('active', btnField === field);
                var arrow = sortBtns[i].querySelector('.sort-arrow');
                if (arrow && btnField === field) {
                    arrow.innerHTML = TenderScout.sortDirection === 'desc' ? '&#x25BC;' : '&#x25B2;';
                }
            }
            doSort();
            applyFilters();
        }

        // Event bindings
        var searchInput = document.querySelector('.search-input');
        if (searchInput) {
            searchInput.addEventListener('input', function() {
                searchTable(this.value);
            });
        }

        var clearBtn = document.querySelector('.search-clear');
        if (clearBtn) {
            clearBtn.addEventListener('click', function() {
                var input = document.querySelector('.search-input');
                if (input) { input.value = ''; }
                searchTable('');
            });
        }

        var filterBtns = document.querySelectorAll('.filter-btn');
        for (var i = 0; i < filterBtns.length; i++) {
            filterBtns[i].addEventListener('click', function() {
                filterSource(this.getAttribute('data-source'));
            });
        }

        var sortBtns = document.querySelectorAll('.sort-btn');
        for (var i = 0; i < sortBtns.length; i++) {
            sortBtns[i].addEventListener('click', function() {
                sortTable(this.getAttribute('data-sort'));
            });
        }
    </script>
</body>
</html>
